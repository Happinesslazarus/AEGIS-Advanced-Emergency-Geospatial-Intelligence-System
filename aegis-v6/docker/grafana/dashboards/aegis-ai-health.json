{
  "uid": "aegis-ai-health",
  "title": "AEGIS — AI Health",
  "tags": ["aegis", "ai"],
  "timezone": "browser",
  "refresh": "15s",
  "time": { "from": "now-3h", "to": "now" },
  "panels": [
    {
      "title": "AI Engine Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }]
        }
      },
      "targets": [{ "expr": "up{job=\"aegis-ai-engine\"}", "legendFormat": "AI Engine", "refId": "A" }]
    },
    {
      "title": "Model Drift Scores",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "custom": { "thresholdsStyle": { "mode": "line" } }, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 0.5, "color": "yellow" }, { "value": 0.7, "color": "red" }] } }
      },
      "targets": [
        { "expr": "aegis_model_drift_score", "legendFormat": "{{ hazard }}/{{ region }}/{{ version }}", "refId": "A" }
      ]
    },
    {
      "title": "Model Alert Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": {
          "mappings": [{ "type": "value", "options": { "0": { "text": "Healthy", "color": "green" }, "1": { "text": "Info", "color": "blue" }, "2": { "text": "Warning", "color": "yellow" }, "3": { "text": "Critical", "color": "red" } } }]
        }
      },
      "targets": [{ "expr": "aegis_model_alert_status", "legendFormat": "{{ hazard }}/{{ region }}", "refId": "A" }]
    },
    {
      "title": "Degraded Models",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "" },
      "fieldConfig": {
        "defaults": { "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] } }
      },
      "targets": [{ "expr": "sum(aegis_model_degraded == 1) or vector(0)", "legendFormat": "Degraded", "refId": "A" }]
    },
    {
      "title": "Prediction Throughput",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "sum(rate(ai_predictions_total[5m])) by (hazard_type)", "legendFormat": "{{ hazard_type }}", "refId": "A" },
        { "expr": "sum(rate(aegis_predictions_total[5m])) by (hazard_type)", "legendFormat": "engine:{{ hazard_type }}", "refId": "B" }
      ]
    },
    {
      "title": "Prediction Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(ai_prediction_seconds_bucket[5m])) by (le))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum(rate(ai_prediction_seconds_bucket[5m])) by (le))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum(rate(ai_prediction_seconds_bucket[5m])) by (le))", "legendFormat": "p99", "refId": "C" }
      ]
    },
    {
      "title": "Model Confidence",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "aegis_model_avg_confidence", "legendFormat": "{{ hazard }}/{{ region }}/{{ version }}", "refId": "A" }
      ]
    },
    {
      "title": "Fallback Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "sum(rate(aegis_model_fallback_total[5m])) by (hazard, region)", "legendFormat": "{{ hazard }}/{{ region }}", "refId": "A" }
      ]
    },
    {
      "title": "AI Engine — Models Loaded",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [{ "expr": "aegis_models_loaded", "legendFormat": "Loaded", "refId": "A" }]
    },
    {
      "title": "AI Engine Errors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "" },
      "targets": [
        { "expr": "rate(aegis_errors_total[5m])", "legendFormat": "{{ error_type }}", "refId": "A" }
      ]
    }
  ]
}
