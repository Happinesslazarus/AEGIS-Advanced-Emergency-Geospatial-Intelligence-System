# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# AEGIS Server Environment Configuration
# Copy this file to .env and fill in your values
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

# PostgreSQL connection (install PostgreSQL + PostGIS locally)
DATABASE_URL=postgresql://postgres:PLACEHOLDER_DB_PASSWORD@localhost:5432/aegis

# NOTE: All values below marked PLACEHOLDER should be replaced with real
# secure values. Never commit a real .env file into source control.

# JWT secret for authentication tokens (change this to a random string)
JWT_SECRET=PLACEHOLDER_JWT_SECRET_32_PLUS_CHARS
REFRESH_TOKEN_SECRET=PLACEHOLDER_REFRESH_TOKEN_SECRET_32_PLUS_CHARS

# Server port
PORT=3001

# OpenWeatherMap API key (free at https://openweathermap.org/api)
WEATHER_API_KEY=PLACEHOLDER_OPENWEATHER_API_KEY

# File upload directory
UPLOAD_DIR=./uploads

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# Internal AI engine URL
AI_ENGINE_URL=http://localhost:8000
AI_ENGINE_TIMEOUT=30000

# Local Ollama model profile
# Recommended profile for 8GB GPUs:
# qwen3:8b as the main local chat model
# qwen3:4b as the fast conversational fallback
# qwen3:1.7b as the ultrafast low-cost model
# qwen2.5vl:7b as the local vision fallback
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PRIMARY_MODEL=qwen3:8b
OLLAMA_FAST_MODEL=qwen3:4b
OLLAMA_SPECIALIST_MODEL=qwen3:8b
OLLAMA_ULTRAFAST_MODEL=qwen3:1.7b
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_VISION_TRIAGE_MODEL=

# Dynamic content translation providers (server-side only)
AZURE_TRANSLATOR_KEY=PLACEHOLDER_AZURE_TRANSLATOR_KEY
AZURE_TRANSLATOR_REGION=PLACEHOLDER_AZURE_TRANSLATOR_REGION
AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com/

DEEPL_API_KEY=PLACEHOLDER_DEEPL_API_KEY
DEEPL_ENDPOINT=https://api-free.deepl.com/v2/translate

# Optional comma-separated override list for LibreTranslate public/self-hosted endpoints
LIBRE_TRANSLATE_ENDPOINT=

# n8n workflow automation
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=PLACEHOLDER_N8N_API_KEY
N8N_WEBHOOK_SECRET=PLACEHOLDER_N8N_WEBHOOK_SECRET
# NASA FIRMS wildfire satellite data (free key from https://firms.modaps.eosdis.nasa.gov/api/area/)
NASA_FIRMS_API_KEY=PLACEHOLDER_NASA_FIRMS_API_KEY
# Password reset URL base (token is appended as query string)
RESET_PASSWORD_URL=http://localhost:5173/reset-password

# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
# Alert Provider Configuration (Production)
# â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

# SMTP Email Configuration (use Gmail, SendGrid, AWS SES, or any SMTP provider)
SMTP_HOST=PLACEHOLDER_SMTP_HOST
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=PLACEHOLDER_SMTP_USER
SMTP_PASS=PLACEHOLDER_SMTP_PASS
SMTP_FROM=alerts@example.org
SMTP_FROM_NAME="AEGIS Alert System"

# Twilio SMS Configuration (sign up at https://www.twilio.com)
TWILIO_ACCOUNT_SID=PLACEHOLDER_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=PLACEHOLDER_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=PLACEHOLDER_TWILIO_PHONE_NUMBER

# Telegram Bot Configuration (create bot via @BotFather)
TELEGRAM_BOT_TOKEN=PLACEHOLDER_TELEGRAM_BOT_TOKEN

# WhatsApp via Twilio (requires approved Twilio WhatsApp sender)
TWILIO_WHATSAPP_NUMBER=PLACEHOLDER_TWILIO_WHATSAPP

# Web Push Notifications (VAPID keys - generate with: npx tsx src/utils/generateVapidKeys.ts)
VAPID_PUBLIC_KEY=PLACEHOLDER_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=PLACEHOLDER_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@example.org

# Two-Factor Authentication (2FA) encryption key
# Used to encrypt TOTP secrets at rest. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Must be exactly 64 hex characters (32 bytes). Required in production.
TWO_FACTOR_ENCRYPTION_KEY=PLACEHOLDER_64_HEX_CHARS_GENERATE_WITH_CRYPTO
