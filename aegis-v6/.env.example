# AEGIS v6.9 — Environment Variables Template
# Copy to .env and fill in real values before deploying.

# Database
DB_PASSWORD=aegis_secure_2026
DATABASE_URL=postgresql://postgres:aegis_secure_2026@localhost:5432/aegis

# Auth
JWT_SECRET=change-this-to-a-random-64-char-string

# Redis Cache
# Set REDIS_ENABLED=false to disable Redis and fall back to in-memory LRU cache.
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379
REDIS_DEFAULT_TTL_SECONDS=300
REDIS_STALE_GRACE_SECONDS=600
REDIS_CONNECT_TIMEOUT_MS=5000

# Region & Locale
# AEGIS_REGION: deployment region slug (e.g. scotland, england, nigeria, australia).
# Controls which regional news feeds and data sources are included.
AEGIS_REGION=scotland

# AEGIS_DEFAULT_LAT / AEGIS_DEFAULT_LON: centre-point of the deployment area.
# Used as default coordinates for weather/air-quality data ingestion.
# Example values below are for Aberdeen, Scotland. Replace for your region.
AEGIS_DEFAULT_LAT=57.1497
AEGIS_DEFAULT_LON=-2.0943

# AEGIS_TIMEZONE: IANA timezone string for the deployment region.
# Used in weather API calls and date/time formatting.
# Examples: UTC, Europe/London, America/New_York, Africa/Lagos, Asia/Tokyo
AEGIS_TIMEZONE=Europe/London

# Regional Data Sources
# AEGIS_FLOOD_RSS_URL: RSS feed URL from the regional flood authority.
# Defaults to SEPA (Scotland) when not set.
AEGIS_FLOOD_RSS_URL=https://www.sepa.org.uk/rss/current-flood-warnings.rss
AEGIS_FLOOD_AUTHORITY=SEPA
AEGIS_FLOOD_AUTHORITY_URL=https://www.sepa.org.uk/environment/water/flooding/

# AEGIS_WEATHER_AUTHORITY: display name of the regional meteorological authority.
# AEGIS_WEATHER_WARNINGS_URL: RSS URL for weather warnings (leave blank for Met Office default).
AEGIS_WEATHER_AUTHORITY=Met Office
AEGIS_WEATHER_WARNINGS_URL=

# AEGIS_NEWS_FEEDS: optional extra news RSS feeds as a JSON array.
# e.g. [{"source":"National Weather Service","url":"https://alerts.weather.gov/cap/us.php"}]
AEGIS_NEWS_FEEDS=

# AI / LLM API Keys (free tiers)
# At least one LLM key is needed for chat to work.
# The system rotates between available providers automatically.
GEMINI_API_KEY=PLACEHOLDER_GEMINI_API_KEY
GROQ_API_KEY=PLACEHOLDER_GROQ_API_KEY
OPENROUTER_API_KEY=PLACEHOLDER_OPENROUTER_API_KEY
HF_API_KEY=PLACEHOLDER_HF_API_KEY

# Weather
OPENWEATHER_API_KEY=PLACEHOLDER_OPENWEATHER_API_KEY

# Email (SMTP)
SMTP_HOST=PLACEHOLDER_SMTP_HOST
SMTP_PORT=587
SMTP_USER=PLACEHOLDER_SMTP_USER
SMTP_PASS=PLACEHOLDER_SMTP_PASS

# SMS (Twilio)
TWILIO_ACCOUNT_SID=PLACEHOLDER_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=PLACEHOLDER_TWILIO_AUTH_TOKEN
TWILIO_FROM=PLACEHOLDER_TWILIO_FROM

# Telegram Bot
TELEGRAM_BOT_TOKEN=PLACEHOLDER_TELEGRAM_BOT_TOKEN

# Web Push (VAPID)
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=PLACEHOLDER_VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=PLACEHOLDER_VAPID_PRIVATE_KEY
VAPID_SUBJECT=mailto:admin@example.org

# Frontend (Vite) env vars — prefix with VITE_
# VITE_NOMINATIM_COUNTRY_CODES: ISO 3166-1 alpha-2 codes (comma-separated)
# used to bias the address search in the report form.
# Leave blank for global search, or set to e.g. "gb" for UK-only, "us,ca" for North America.
VITE_NOMINATIM_COUNTRY_CODES=gb
VITE_MAPBOX_TOKEN=PLACEHOLDER_VITE_MAPBOX_TOKEN

# AI Engine
API_SECRET_KEY=PLACEHOLDER_API_SECRET_KEY
