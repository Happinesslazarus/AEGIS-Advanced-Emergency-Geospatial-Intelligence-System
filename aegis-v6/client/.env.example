# Client (Vite) environment variables
# Copy this file to client/.env and replace PLACEHOLDER values.
# Never commit the real client/.env to source control.

# Public mapbox token for map tiles (replace with your token)
VITE_MAPBOX_TOKEN=PLACEHOLDER_VITE_MAPBOX_TOKEN

# Public API URL used by the client to reach backend (no secrets here)
VITE_API_URL=http://localhost:3001

# Optional frontend feature flags
VITE_ENABLE_3D=false
