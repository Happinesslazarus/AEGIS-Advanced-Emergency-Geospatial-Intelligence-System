# Service
AI_ENGINE_PORT=8000
MODEL_REGISTRY_PATH=registry/model_versions
INTERNAL_API_KEY=PLACEHOLDER_INTERNAL_API_KEY_MIN_32_CHARS
API_SECRET_KEY=PLACEHOLDER_API_SECRET_KEY_MIN_32_CHARS
DRIFT_THRESHOLD=0.15
LOG_LEVEL=INFO
LOG_FORMAT=json

# Data credentials (all optional — synthetic fallback if missing)
# Copernicus CDS (ERA5, CHESS-SCAPE) — free at https://cds.climate.copernicus.eu
CDS_API_KEY=PLACEHOLDER_CDS_API_KEY
CDS_API_URL=https://cds.climate.copernicus.eu/api/v2

# NASA Earthdata (GPM, MODIS) — free at https://urs.earthdata.nasa.gov
NASA_EARTHDATA_USER=PLACEHOLDER_NASA_USER
NASA_EARTHDATA_PASS=PLACEHOLDER_NASA_PASS

# CEDA Archive (HadUK, CHESS) — free at https://services.ceda.ac.uk
CEDA_USERNAME=PLACEHOLDER_CEDA_USERNAME
CEDA_PASSWORD=PLACEHOLDER_CEDA_PASSWORD

# Training
SYNTHETIC_FALLBACK=true
AUTO_TRAIN_ON_STARTUP=false
TRAINING_DATA_PATH=data/processed
ACTIVE_REGION=scotland

# Optional cloud credentials used during training/data downloads
S3_BUCKET=PLACEHOLDER_S3_BUCKET
S3_ACCESS_KEY_ID=PLACEHOLDER_S3_ACCESS_KEY
S3_SECRET_ACCESS_KEY=PLACEHOLDER_S3_SECRET

# UK Expansion (flip to true when ready to activate)
ENABLE_ENGLAND=false
ENABLE_WALES=false
ENABLE_NORTHERN_IRELAND=false
