{
  "version": 1,
  "goal": "Build a world-class local disaster vision dataset for AEGIS using a curated multi-source manifest instead of a single monolithic dataset.",
  "target_taxonomy": [
    "wildfire",
    "flood",
    "earthquake",
    "storm",
    "landslide",
    "drought",
    "structural_damage",
    "heatwave",
    "safe"
  ],
  "recommended_split_policy": {
    "evaluation_minimum": 1000,
    "training_target_initial": 12000,
    "training_target_strong": 20000,
    "notes": [
      "Keep evaluation isolated from training.",
      "Prioritize citizen-photo and social-media style imagery for chatbot use cases.",
      "Use aerial and satellite datasets as auxiliary pretraining data, not the only source."
    ]
  },
  "sources": [
    {
      "source_id": "aegis_benchmark",
      "name": "AEGIS Internal Vision Benchmark",
      "priority": 1,
      "role": "smoke_test",
      "domain": "citizen_photo",
      "license": "internal",
      "ingestion_type": "benchmark_json",
      "acquisition_mode": "in_repo",
      "requires_manual_registration": false,
      "annotation_path": "data/vision_benchmark.json",
      "image_root": "../server/uploads/chat/benchmark",
      "notes": [
        "Current internal benchmark.",
        "Useful for regression checks only.",
        "Too small to train or to serve as the main evaluation set."
      ]
    },
    {
      "source_id": "aegis_reports_curated",
      "name": "AEGIS Curated Citizen Reports",
      "priority": 1,
      "role": "core_training",
      "domain": "citizen_photo",
      "license": "internal_reviewed",
      "ingestion_type": "folder_by_class",
      "acquisition_mode": "manual_internal_curation",
      "requires_manual_registration": false,
      "image_root": "datasets/aegis_reports_curated",
      "notes": [
        "Highest-priority future source because it matches the deployment domain.",
        "Should be manually reviewed and deduplicated.",
        "Use this as the backbone of the final production dataset."
      ]
    },
    {
      "source_id": "crisismmd",
      "name": "CrisisMMD",
      "priority": 2,
      "role": "core_training",
      "domain": "social_media",
      "license": "research_dataset",
      "ingestion_type": "folder_by_class",
      "acquisition_mode": "direct_download",
      "requires_manual_registration": false,
      "expected_download_size_gb": 1.8,
      "image_root": "datasets/crisismmd",
      "source_url": "https://crisisnlp.qcri.org/crisismmd",
      "official_download_url": "https://crisisnlp.qcri.org/data/crisismmd/CrisisMMD_v2.0.tar.gz",
      "annotations_download_url": "https://crisisnlp.qcri.org/data/crisismmd/crisismmd_datasplit_all.zip",
      "notes": [
        "Best external source here for image uploads that resemble real public crisis imagery.",
        "Use for wildfire, flood, earthquake, storm, damage, and safe or irrelevant negatives.",
        "Remap to AEGIS taxonomy during manifest generation."
      ]
    },
    {
      "source_id": "floodnet",
      "name": "FloodNet",
      "priority": 3,
      "role": "auxiliary_training",
      "domain": "uas_aerial",
      "license": "research_dataset",
      "ingestion_type": "folder_by_class",
      "acquisition_mode": "manual_download",
      "requires_manual_registration": false,
      "expected_download_size_gb": 2.0,
      "image_root": "datasets/floodnet",
      "source_url": "https://github.com/BinaLab/FloodNet-Challenge-EARTHVISION2021",
      "official_download_url": "https://drive.google.com/drive/folders/1sZZMJkbqJNbHgebKvHzcXYZHJd6ss4tH?usp=sharing",
      "notes": [
        "Strong flood-specific auxiliary source.",
        "Useful for flood localization and context, but domain-shifted from phone uploads."
      ]
    },
    {
      "source_id": "xbd_xview2",
      "name": "xBD / xView2",
      "priority": 3,
      "role": "auxiliary_training",
      "domain": "satellite",
      "license": "challenge_dataset",
      "ingestion_type": "folder_by_class",
      "acquisition_mode": "manual_registration_required",
      "requires_manual_registration": true,
      "expected_download_size_gb": 11.0,
      "image_root": "datasets/xbd_xview2",
      "source_url": "https://xview2.org/dataset",
      "official_download_url": "https://xview2.org",
      "notes": [
        "Excellent for damage and disaster-scene supervision.",
        "Use as auxiliary data for structural damage, wildfire, flood, and storm damage.",
        "Do not let it dominate the final citizen-facing classifier because the view angle is different."
      ]
    }
  ]
}
